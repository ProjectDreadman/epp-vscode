{
  "name": "E++",
  "scopeName": "source.epp",
  "fileTypes": ["epp", "erb"],
  "patterns": [
    { "include": "#preprocessor" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#numbers" },
    { "include": "#keywords-control" },
    { "include": "#keywords-types" },
    { "include": "#keywords-storage" },
    { "include": "#keywords-oop" },
    { "include": "#keywords-exceptions" },
    { "include": "#keywords-io" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.epp",
          "match": "^\\s*(#inclerb|#deferberb|#praerb|#ifderb|#ifnerb|#endifberb|#unerberb)\\b",
          "captures": {
            "1": { "name": "keyword.control.preprocessor.epp" }
          }
        },
        {
          "name": "meta.preprocessor.include.epp",
          "match": "^\\s*(#inclerb)\\s*([<\"][^>\"]+[>\"])",
          "captures": {
            "1": { "name": "keyword.control.preprocessor.epp" },
            "2": { "name": "string.quoted.other.include.epp" }
          }
        },
        {
          "name": "meta.preprocessor.define.epp",
          "match": "^\\s*(#deferberb)\\s+([A-Z_][A-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.control.preprocessor.epp" },
            "2": { "name": "entity.name.constant.epp" }
          }
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.block.epp",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.epp" } },
          "endCaptures": { "0": { "name": "punctuation.definition.comment.end.epp" } }
        },
        {
          "name": "comment.line.double-slash.epp",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.epp",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.epp", "match": "\\\\." }
          ]
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "string.quoted.single.epp",
          "match": "'([^'\\\\]|\\\\.)'"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.epp",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.epp",
          "match": "\\b[0-9]+\\.[0-9]*([eE][+-]?[0-9]+)?[fFlL]?\\b"
        },
        {
          "name": "constant.numeric.integer.epp",
          "match": "\\b[0-9]+([uUlL]*)\\b"
        }
      ]
    },
    "keywords-control": {
      "patterns": [
        {
          "name": "keyword.control.epp",
          "match": "\\b(iferb|elserb|elserbiferb|swerb|caserb|deferb|brerb|conterb|returnerb|goerb|ferb|wherb|doerb)\\b"
        }
      ]
    },
    "keywords-types": {
      "patterns": [
        {
          "name": "storage.type.epp",
          "match": "\\b(nerb|flerb|derb|cherb|blerb|verbd|lerbon|sherb|sterbing|auerb|unserb|signerb|typerbn|typerb)\\b"
        },
        {
          "name": "constant.language.boolean.epp",
          "match": "\\b(truerb|falserb|nullerb)\\b"
        }
      ]
    },
    "keywords-storage": {
      "patterns": [
        {
          "name": "storage.modifier.epp",
          "match": "\\b(consterb|sterbing|exterberb|inlerb|volerb|sizerb)\\b"
        }
      ]
    },
    "keywords-oop": {
      "patterns": [
        {
          "name": "storage.type.class.epp",
          "match": "\\b(clerb|sterb|enerb|unerb|namerberb|temperb|verbtual|overberb|finerb|plerb|priverb|proterb|frerb|therb|nerbd|delerb|operberb|userbing|sterbd)\\b"
        }
      ]
    },
    "keywords-exceptions": {
      "patterns": [
        {
          "name": "keyword.control.exception.epp",
          "match": "\\b(tryerb|catcherb|thowerb)\\b"
        }
      ]
    },
    "keywords-io": {
      "patterns": [
        {
          "name": "support.function.io.epp",
          "match": "\\b(cerbt|cinnerb|endlerb)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.epp",
          "match": "(<<|>>|->|::|\\+\\+|--|&&|\\|\\||[+\\-*/%&|^~<>!=]=?|[?:])"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.epp",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.type.epp",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "variable.other.epp",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
