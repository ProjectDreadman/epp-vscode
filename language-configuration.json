{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "<", "close": ">", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["<", ">"]
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "indentationRules": {
    "increaseIndentPattern": "^((?!.*\\bcase\\b).*\\{[^}\"'`]*|\\b(iferb|elserb|ferb|wherb|doerb)\\b[^;]*)[\\s]*$",
    "decreaseIndentPattern": "^[\\s]*[}\\])]"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*\\/\\*\\*(?!\\/)([^\\*]|\\*(?!\\/))*$",
      "afterText": "^\\s*\\*\\/$",
      "action": { "indent": "indentOutdent", "appendText": " * " }
    },
    {
      "beforeText": "^\\s*\\/\\*\\*(?!\\/)([^\\*]|\\*(?!\\/))*$",
      "action": { "indent": "none", "appendText": " * " }
    },
    {
      "beforeText": "^(\\t|( {2}))* \\*( ([^*]|\\*(?!\\/))*)?$",
      "action": { "indent": "none", "appendText": "* " }
    },
    {
      "beforeText": "^(\\t|( {2}))* \\*\\/\\s*$",
      "action": { "indent": "none", "removeText": 1 }
    }
  ]
}
